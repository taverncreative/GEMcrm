# ─── Supabase (required) ──────────────────────────────────────
# Find these in your Supabase project: Settings → API.
# The anon key is safe to expose to the browser (RLS enforces auth).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase service role (required for inviting users) ──────
# This key bypasses RLS — NEVER expose to the browser. Used only in
# server actions that need admin powers (Settings → Invite teammate).
# Find it in: Supabase → Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ─── Resend email (required in production) ────────────────────
# Sign up at https://resend.com, verify your sending domain, then create
# an API key under Settings → API Keys.
#
# Without RESEND_API_KEY the email service falls back to console.log in
# dev — workflows still run end-to-end, just no real mail is sent.
RESEND_API_KEY=
# Must be a verified sender on the Resend domain you set up. Verification is
# at the ROOT of the domain, so any mailbox on it is already authorised — a
# systematic address keeps the automated mail from reading as personal mail.
# Example: "GEM Services <reports@gemservices.uk>"
RESEND_FROM_EMAIL="GEM Services <reports@gemservices.uk>"
# OPTIONAL. Reply-To applied to EVERY send. Point this at a real inbox so a
# customer hitting Reply still reaches a human, and so a reply can never
# bounce off a From address with no mailbox behind it.
# Unset = no Reply-To header at all (the safe default).
RESEND_REPLY_TO="nate@gemservices.uk"


# ─── Review link (optional) ───────────────────────────────────
# Override the hardcoded Google review URL in lib/constants/branding.ts.
# Useful if you have a shorter link or change Google Business listing.
# REVIEW_LINK_URL=https://g.page/r/your-review-link


# ─── Cron protection (required in production) ─────────────────
# A long random string. Vercel cron requests must include this in the
# Authorization header so they can't be invoked by anyone with the URL.
# Generate with `openssl rand -hex 32`.
CRON_SECRET=


# ─── Spotlight ingest (optional) ──────────────────────────────
# Pushes submitted feature requests into the separate Spotlight CRM so
# they land in a triageable list. BEST EFFORT: if these are unset the
# POST is skipped silently and the feature_requests row + the email to
# the support inbox remain the record. A Spotlight outage never fails
# the operator's submit.
# The token also identifies the source app, so we do NOT send source_app.
SPOTLIGHT_INGEST_URL=
SPOTLIGHT_INGEST_TOKEN=
